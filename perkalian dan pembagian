#include <stdio.h>
/* Kalkulator dibuat oleh Azka - fitur dasar matematika */
int main() {
    int a, b;

    printf("Masukkan angka pertama: ");
    scanf("%d", &a);

    printf("Masukkan angka kedua: ");
    scanf("%d", &b);

    printf("Perkalian: %d\n", a * b);
    printf("Pembagian: %d\n", a / b);

    return 0;
}
